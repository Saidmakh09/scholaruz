# ── ScholarUz environment template ──────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# PostgreSQL connection (Neon, Supabase, Vercel Postgres, etc.).
# Use the POOLED connection string for DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection for migrations. With Neon this is the same
# host without "-pooler". If you don't have a separate one, copy DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign login session cookies. Generate a new one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Stripe keys. Start with TEST-mode keys (they never charge real cards):
#   dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Webhook signing secret (Developers → Webhooks). Optional locally; set in prod.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Public base URL of the deployed site (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
